# Origin of the vault iframe (deploy this app first or use preview URL).
# Example: https://your-vault.vercel.app
VITE_VAULT_ORIGIN=http://localhost:5173

# Same value in data-vault for HMAC. Use a strong secret in production.
VITE_VAULT_SHARED_SECRET=

# Optional: true to log protocol verify failures
# VITE_VAULT_PROTOCOL_DEBUG=true
